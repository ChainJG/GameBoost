<UserControl
    x:Class="GameBoost.MVVM.UserControls.Shared.Cards.SelectionActionCardUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameBoost.MVVM.UserControls.Shared.Cards"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="410"
    Height="55"
    mc:Ignorable="d">

    <ToggleButton
        Width="400"
        Height="50"
        IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        Style="{StaticResource ActionCardToggleButtonStyle}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox
                Grid.Column="0"
                Width="20"
                Height="20"
                Focusable="False"
                IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                IsHitTestVisible="False" />

            <materialDesign:PackIcon
                Grid.Column="1"
                Width="30"
                Height="30"
                Kind="{Binding Icon, FallbackValue=QuestionMark}" />

            <TextBlock
                Grid.Column="2"
                MaxWidth="250"
                HorizontalAlignment="Left"
                Style="{StaticResource ButtonTitleStyle}"
                Text="{Binding Title}"
                TextWrapping="Wrap" />

            <TextBlock
                Grid.Column="2"
                Margin="0,0,15,0"
                HorizontalAlignment="Right"
                Style="{StaticResource ButtonSubTitleStyle}"
                Text="{Binding Status}"
                TextWrapping="Wrap" />

        </Grid>
    </ToggleButton>
</UserControl>