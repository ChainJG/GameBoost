<UserControl
    x:Class="GameBoost.MVVM.UserControls.Shared.Cards.SelectionResultCardUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameBoost.MVVM.UserControls.Shared.Cards"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="410"
    Height="55"
    mc:Ignorable="d">

    <Border Width="400" Height="50">

        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <materialDesign:PackIcon
                Width="35"
                Height="35"
                Kind="{Binding Icon, FallbackValue=QuestionMark}" />

            <TextBlock
                Grid.Column="1"
                MaxWidth="250"
                HorizontalAlignment="Left"
                Style="{StaticResource ButtonTitleStyle}"
                Text="{Binding Title}"
                TextWrapping="Wrap" />

            <!--#region Status Text-->
            <TextBlock
                Grid.Column="1"
                MaxWidth="100"
                Margin="0,0,5,0"
                HorizontalAlignment="Right"
                TextWrapping="Wrap">

                <TextBlock.Style>
                    <Style BasedOn="{StaticResource ButtonSubTitleStyle}" TargetType="{x:Type TextBlock}">

                        <Setter Property="Text" Value="{Binding Status}" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Running">
                                <Setter Property="Text" Value="Running..." />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <!--#endregion-->

            <!--#region Result Icon-->
            <materialDesign:PackIcon
                x:Name="ResultIcon"
                Grid.Column="2"
                Width="35"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <materialDesign:PackIcon.Style>

                    <Style TargetType="materialDesign:PackIcon">

                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Foreground" Value="{StaticResource IconKindColor}" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding State}" Value="Result">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Result.Success}" Value="True">
                                <Setter Property="Kind" Value="Check" />
                                <Setter Property="Foreground" Value="{StaticResource GreenColour}" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Result.Success}" Value="False">
                                <Setter Property="Kind" Value="Close" />
                                <Setter Property="Foreground" Value="{StaticResource WarningColour}" />
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </materialDesign:PackIcon.Style>
            </materialDesign:PackIcon>
            <!--#endregion-->

            <!--#region Progress Circle UI-->
            <ProgressBar
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{StaticResource GreenColour}"
                IsIndeterminate="True">

                <ProgressBar.Style>
                    <Style BasedOn="{StaticResource MaterialDesignCircularProgressBar}" TargetType="{x:Type ProgressBar}">

                        <Setter Property="Visibility" Value="Collapsed" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Running">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>

                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
            <!--#endregion-->

        </Grid>
    </Border>
</UserControl>
