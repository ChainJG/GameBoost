<Window
    x:Class="GameBoost.MVVM.Windows.SplashScreenWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:GameBoost.MVVM.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameBoost.MVVM.Windows"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Pulse Profiler - Loading"
    Width="600"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <materialDesign:Card Background="{StaticResource PrimaryPanelColour}" UniformCornerRadius="10">

        <Grid>

            <!--  Icon  -->
            <Border
                Height="25"
                Margin="412.5,212,0,162"
                Background="{StaticResource IconKindColor}"
                Opacity=".1" />
            <Border
                Height="25"
                Margin="0,212,412.5,162"
                Background="{StaticResource IconKindColor}"
                Opacity=".1" />
            <materialDesign:PackIcon
                Width="300"
                Height="300"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{StaticResource IconKindColor}"
                Kind="Pulse"
                Opacity=".1" />

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!--  Title  -->
                <TextBlock
                    FontSize="32"
                    Style="{StaticResource TitleStyle}"
                    Text="GameBoost" />

                <!--  SubTitle  -->
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource SubTitleStyle}"
                    Text="Windows 11 Optimisation Tool" />

            </StackPanel>


            <StackPanel
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Orientation="Vertical">

                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar
                        Width="40"
                        Height="40"
                        behaviors:ProgressBarAnimationBehavior.SmoothValue="{Binding ProgressPercentage}"
                        Foreground="{StaticResource GreenColour}"
                        Maximum="100"
                        Style="{StaticResource MaterialDesignCircularProgressBar}"
                        Value="0" />

                    <TextBlock
                        x:Name="ProgressTextBlock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource SubTitleStyle}"
                        Text="{Binding ProgressPercentage, StringFormat={}{0}%}" />
                </Grid>

                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="Bahnschrift"
                    FontSize="12"
                    Style="{StaticResource TitleStyle}"
                    Text="{Binding StatusMessage}"
                    TextAlignment="Center" />

                <!--  Version Info  -->
                <TextBlock
                    x:Name="VersionTextBlock"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    Style="{StaticResource SubTitleStyle}"
                    Text="{Binding VersionText}" />
            </StackPanel>

        </Grid>
    </materialDesign:Card>
</Window>