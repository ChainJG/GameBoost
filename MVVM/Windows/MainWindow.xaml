<Window
    x:Class="GameBoost.MVVM.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:GameBoost.MVVM.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameBoost"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GameBoost.MVVM.ViewModels"
    Title="GameBoost"
    Width="1025"
    Height="640"
    d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>
        <materialDesign:Card
            Width="1025"
            Height="600"
            VerticalAlignment="Top"
            Background="{StaticResource PrimaryPanelColour}"
            UniformCornerRadius="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--#region Title Bar-->
                <Grid
                    Grid.Row="0"
                    Background="{StaticResource SecondaryPanelColour}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <!--#region GameBoost Logo-->
                    <StackPanel
                        Grid.Column="0"
                        Margin="15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <materialDesign:PackIcon Margin="0,0,5,0" Kind="Pulse" />
                        <TextBlock Style="{StaticResource SubTitleStyle}" Text="GameBoost" />
                    </StackPanel>
                    <!--#endregion-->

                    <!--#region Page Display UI-->
                    <StackPanel
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <materialDesign:PackIcon Margin="0,0,5,0" Kind="{Binding PageIcon}" />
                        <TextBlock Style="{StaticResource ButtonSubTitleStyle}" Text="{Binding PageTitle}" />

                    </StackPanel>
                    <!--#endregion-->


                    <!--#region Application Buttons (Minimise, Exit)-->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            Click="BtnMinimiseWindow_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Tag="WindowMinimize" />

                        <Button
                            Click="BtnExitApplication_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Tag="WindowClose" />
                    </StackPanel>
                    <!--#endregion-->

                    <Separator
                        Grid.Column="1"
                        Width="15"
                        Height="1.5"
                        Style="{StaticResource VerticalSeparatorStyle}" />
                </Grid>
                <!--#endregion-->

                <!--#region Page Content View-->
                <ContentControl
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Content="{Binding CurrentView}" />
                <!--#endregion-->

            </Grid>
        </materialDesign:Card>

        <Grid
            x:Name="DockRoot"
            Width="580"
            Height="80"
            Margin="0,0,260,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom">
            <!--#region Dock Panel-->

            <Border
                Width="Auto"
                Height="Auto"
                Background="{StaticResource PrimaryPanelColour}"
                CornerRadius="10" />


            <Border
                x:Name="DockLeft"
                Width="70"
                Margin="5"
                HorizontalAlignment="Left"
                Background="{StaticResource SecondaryPanelColour}"
                CornerRadius="7"
                Opacity="1">
                <Button
                    Width="80"
                    Command="{Binding DockActionCommand}"
                    Content="{Binding DockActionText}"
                    Style="{StaticResource DockActionButtonStyle}"
                    Tag="{Binding DockActionIcon}" />
            </Border>

            <!--#region Dock Center-->
            <Border
                x:Name="DockCenter"
                Grid.Column="1"
                Width="500"
                Margin="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{StaticResource SecondaryPanelColour}"
                CornerRadius="8">
                <ListBox
                    ItemsSource="{Binding Pages}"
                    SelectedItem="{Binding SelectedPage}"
                    Style="{StaticResource DockMenuListBoxStyle}" />
            </Border>
            <!--#endregion-->

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="DockStates">

                    <VisualState x:Name="FullDock">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="DockRoot"
                                Storyboard.TargetProperty="Width"
                                To="580"
                                Duration="0:0:0.15" />

                            <DoubleAnimation
                                Storyboard.TargetName="DockLeft"
                                Storyboard.TargetProperty="Width"
                                To="80"
                                Duration="0:0:0.15" />

                            <DoubleAnimation
                                Storyboard.TargetName="DockLeft"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.10" />

                            <local:CornerRadiusAnimation
                                Storyboard.TargetName="DockCenter"
                                Storyboard.TargetProperty="CornerRadius"
                                From="10"
                                To="0"
                                Duration="0:0:0" />

                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="CompactDock">
                        <Storyboard>

                            <DoubleAnimation
                                Storyboard.TargetName="DockRoot"
                                Storyboard.TargetProperty="Width"
                                To="510"
                                Duration="0:0:0.15" />

                            <DoubleAnimation
                                Storyboard.TargetName="DockLeft"
                                Storyboard.TargetProperty="Width"
                                To="0"
                                Duration="0:0:0.15" />

                            <local:CornerRadiusAnimation
                                Storyboard.TargetName="DockCenter"
                                Storyboard.TargetProperty="CornerRadius"
                                From="0"
                                To="10"
                                Duration="0:0:0.3" />

                        </Storyboard>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
        <!--#endregion-->

    </Grid>

</Window>
