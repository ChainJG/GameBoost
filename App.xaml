<Application
    x:Class="GameBoost.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:GameBoost">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />

                <ResourceDictionary Source="Styles/Core/ColourDictionary.xaml" />
                <ResourceDictionary Source="Styles/Buttons/Dock/DockButtonStyle.xaml" />
                <ResourceDictionary Source="Styles/CheckBox/CheckBoxStyle.xaml" />
                <ResourceDictionary Source="Styles/TextBlock/TextStyles.xaml" />
                <ResourceDictionary Source="Styles/Lines/VerticalSeparatorStyle.xaml" />

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>
</Application>