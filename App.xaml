<Application
    x:Class="GameBoost.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:GameBoost"
    xmlns:viewModels="clr-namespace:GameBoost.MVVM.ViewModels"
    xmlns:views="clr-namespace:GameBoost.MVVM.UserControls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />

                <ResourceDictionary Source="Styles/Core/ColourDictionary.xaml" />
                <ResourceDictionary Source="Styles/TextBlock/TextStyles.xaml" />

                <ResourceDictionary Source="Styles/Icons/PackIconStyles.xaml" />
                <ResourceDictionary Source="Styles/CheckBox/CheckBoxStyle.xaml" />

                <ResourceDictionary Source="Styles/Buttons/Dock/DockButtonStyle.xaml" />
                <ResourceDictionary Source="Styles/Buttons/Dock/DockActionButtonStyle.xaml" />
                <ResourceDictionary Source="Styles/Lines/VerticalSeparatorStyle.xaml" />
                <ResourceDictionary Source="Styles/Buttons/TitleBar/TitleBarButtonStyle.xaml" />
                <ResourceDictionary Source="/Styles/ListBoxItem/CleanListBoxItemStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
                <views:HomeUserControl />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:WindowsViewModel}">
                <views:WindowsUserControl />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:SystemViewModel}">
                <views:SystemUserControl />
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>