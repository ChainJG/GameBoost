<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Style x:Key="{x:Type materialDesign:PackIcon}" TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Foreground" Value="{StaticResource IconKindColor}" />
        <Setter Property="Kind" Value="QuestionMark" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="WatermarkStyle" TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Foreground" Value="{StaticResource IconKindColor}" />
        <Setter Property="Kind" Value="QuestionMark" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value=".5" />
    </Style>
</ResourceDictionary>