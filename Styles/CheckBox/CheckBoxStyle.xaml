<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>

                        <!--  Background box  -->
                        <Border
                            x:Name="Box"
                            Background="#20FFFFFF"
                            CornerRadius="6">

                            <Grid>
                                <!--  Tick Icon  -->
                                <materialDesign:PackIcon
                                    x:Name="TickIcon"
                                    Width="16"
                                    Height="16"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PrimaryPanelColour}"
                                    Kind="Check"
                                    Opacity="0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!--  States  -->
                    <ControlTemplate.Triggers>

                        <!--  Hover  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#30FFFFFF" />
                            <Setter TargetName="TickIcon" Property="Opacity" Value=".5" />
                        </Trigger>

                        <!--  Pressed  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#40FFFFFF" />
                        </Trigger>

                        <!--  Checked  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource GreenColour}" />

                            <Setter TargetName="TickIcon" Property="Opacity" Value="1" />
                        </Trigger>

                        <!--  Disabled  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.4" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>